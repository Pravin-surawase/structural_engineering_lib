# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# Spotlight
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------
# Scratch workbooks created by Excel
Excel/Book*.xlsx

# Local config (if any)
.env
.env.local
*.local.json

# Scratch / temp files
scratch/
temp/
tmp/

# Stale operational data (deleted in Phase 1 cleanup, Mar 2026)
git_operations_log/
metrics/

# Research raw data (too large for git)
docs/research/navigation_study/

# Vendor reference docs (30MB decompiled CHM — keep locally, not in git)
docs/reference/vendor/

# External user artifacts (local only)
external_data/

# -----------------------------------------------------------------------------
# VBA & Excel (kept locally, separate repo planned)
# -----------------------------------------------------------------------------
VBA/
Excel/

# -----------------------------------------------------------------------------
# Local runtime logs (keep out of git)
# -----------------------------------------------------------------------------
logs/*
!logs/README.md

# -----------------------------------------------------------------------------
# Local reference materials (keep out of git)
# -----------------------------------------------------------------------------
docs/_references/downloads_snapshot/

# -----------------------------------------------------------------------------
# Private owner learning notes (local only)
# -----------------------------------------------------------------------------
/docs/learning/
learning-materials/

# -----------------------------------------------------------------------------
# Research Agent daily logs (local only, weekly/monthly summaries tracked)
# -----------------------------------------------------------------------------
research_logs/daily/
docs/_references/downloads-snapshot/
