# Auto-detect text files and normalize line endings
* text=auto

# Force LF for files that are compared byte-for-byte in tests
*.html text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf

# Binary files — do not modify
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.dxf binary
