#!/bin/bash
# Pre-commit hook that enforces automation scripts
# This hook blocks manual git commit unless AI_COMMIT_ACTIVE or SAFE_PUSH_ACTIVE is set
#
# Installed via: ./scripts/install_git_hooks.sh
# Part of: Git Automation Framework (Session 19P6)
#
# When to bypass (set by automation scripts):
#   AI_COMMIT_ACTIVE=1 - Set by ai_commit.sh
#   SAFE_PUSH_ACTIVE=1 - Set by safe_push.sh

# Skip if running through automation (TASK-907: log bypass events)
if [[ -n "$AI_COMMIT_ACTIVE" ]] || [[ -n "$SAFE_PUSH_ACTIVE" ]]; then
    PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
    mkdir -p "$PROJECT_ROOT/logs" 2>/dev/null || true
    BYPASS_LOG="$PROJECT_ROOT/logs/git_workflow.log"
    if [[ -d "$PROJECT_ROOT/logs" ]]; then
        BYPASS_SOURCE=""
        [[ -n "$AI_COMMIT_ACTIVE" ]] && BYPASS_SOURCE="AI_COMMIT_ACTIVE"
        [[ -n "$SAFE_PUSH_ACTIVE" ]] && BYPASS_SOURCE="${BYPASS_SOURCE:+$BYPASS_SOURCE+}SAFE_PUSH_ACTIVE"
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] BYPASS: Commit allowed via $BYPASS_SOURCE (branch: $(git branch --show-current 2>/dev/null || echo unknown))" >> "$BYPASS_LOG"
    fi
    exit 0
fi

# Skip if running in CI
if [[ -n "$CI" ]] || [[ -n "$GITHUB_ACTIONS" ]]; then
    exit 0
fi

# Skip if explicitly bypassed (for emergencies only — LOGGED)
if [[ -n "$GIT_HOOKS_BYPASS" ]]; then
    echo "⚠️  Git hooks bypassed (GIT_HOOKS_BYPASS set)"
    PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
    mkdir -p "$PROJECT_ROOT/logs" 2>/dev/null || true
    if [[ -d "$PROJECT_ROOT/logs" ]]; then
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] WARNING: Commit hook BYPASSED via GIT_HOOKS_BYPASS (branch: $(git branch --show-current 2>/dev/null || echo unknown))" >> "$PROJECT_ROOT/logs/git_workflow.log"
    fi
    exit 0
fi

# Block manual commit
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

# OPS-01: Log blocked event for analysis
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
mkdir -p "$PROJECT_ROOT/logs" 2>/dev/null || true
LOG_FILE="$PROJECT_ROOT/logs/git_workflow.log"
echo "[$(date '+%Y-%m-%d %H:%M:%S')] BLOCKED: Manual git commit attempted (use ai_commit.sh)" >> "$LOG_FILE"

echo ""
echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${RED}❌ MANUAL GIT COMMIT BLOCKED${NC}"
echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo -e "${YELLOW}This repository requires commits through automation scripts.${NC}"
echo ""
echo -e "${YELLOW}Why?${NC} Automation ensures:"
echo "  • Consistent code formatting & linting"
echo "  • Valid commit messages"
echo "  • Pre-commit safeguards run (link checks, version sync)"
echo "  • Proper merge conflict resolution"
echo ""
echo -e "${GREEN}✅ Quick Start:${NC}"
echo "   ./scripts/ai_commit.sh \"your commit message\""
echo ""
echo -e "${YELLOW}That's it!${NC} The script handles:"
echo "  ✓ Format & lint checks (auto-fixes)"
echo "  ✓ Conflict resolution"
echo "  ✓ Safe push"
echo ""
echo -e "${YELLOW}Stuck? Try:${NC}"
echo "   ./scripts/ai_commit.sh --help     (see all options)"
echo "   git status                         (check working tree)"
echo ""
echo -e "${YELLOW}Last resort (NOT recommended):${NC}"
echo "   GIT_HOOKS_BYPASS=1 git commit -m \"message\""
echo ""
echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

exit 1
